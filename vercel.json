{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/calls/clear-all-data",
      "destination": "/api/index.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/auth/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/calls/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/audits/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/build/$1"
    }
  ]
}
